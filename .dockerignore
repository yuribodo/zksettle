# Build context for backend/Dockerfile is the repo root. Without this file
# Docker tarballs *everything* including backend/target/ (~56 GB) and
# node_modules — fatal for build time and disk.
#
# We only need: backend/{Cargo.toml,Cargo.lock,rust-toolchain.toml,programs/,crates/}
# plus circuits/target/zksettle_slice.{json,ccs,pk}.
#
# .gitignore is NOT consulted by docker; this file is the single source of
# truth for build-context exclusions.

# Heavy build outputs
**/target/
**/node_modules/
**/.next/
**/mutants.out/
**/mutants.out.old/
**/dist/

# Frontend / sdk / docs are not built into the backend image
frontend/
sdk/
scripts/
docs/
video/
.github/
.claude/
.superpowers/

# VCS + secrets — never want these in image layers
.git/
.gitignore
.gitattributes
.env
.env.*
*.pem
*.key
**/keypairs/

# Local-only docker / dev orchestration
docker-compose*.yml
.railwayignore

# Misc
**/.DS_Store
**/test-ledger/
**/.anchor/
**/.surfpool/
**/.yarn/
*.log
*.proof
*.wtns

# Re-include the Sunspot circuit artefacts the runtime stage needs.
# Order matters: the broad **/target/ exclusion above hides circuits/target;
# these whitelist the three files back in.
!circuits/target/
circuits/target/*
!circuits/target/zksettle_slice.json
!circuits/target/zksettle_slice.ccs
!circuits/target/zksettle_slice.pk
