{
  "name": "@zksettle/sdk",
  "version": "0.1.1",
  "description": "Zero-knowledge compliance SDK for Solana stablecoins",
  "license": "MIT",
  "author": "ZKSettle Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuribodo/zksettle.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/yuribodo/zksettle#readme",
  "bugs": "https://github.com/yuribodo/zksettle/issues",
  "keywords": [
    "solana",
    "zero-knowledge",
    "zk",
    "compliance",
    "travel-rule",
    "groth16",
    "token-2022",
    "stablecoin",
    "noir"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wrap": {
      "types": "./dist/wrap/index.d.ts",
      "default": "./dist/wrap/index.js"
    },
    "./stablecoin": {
      "types": "./dist/stablecoin/index.d.ts",
      "default": "./dist/stablecoin/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aztec/bb.js": "3.0.0-nightly.20260102",
    "@coral-xyz/anchor": "^0.31.1",
    "@noir-lang/noir_js": "1.0.0-beta.18",
    "bn.js": "^5.2.2",
    "@solana/spl-token": "^0.4.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0"
  }
}
